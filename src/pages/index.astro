---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const features = [
  {
    title: "Identity Coherence",
    text: "A persistent moral identity file anchors the agent's self-understanding so responses remain recognizably continuous across sessions, tasks, and pressures."
  },
  {
    title: "Pascalian Constraint",
    text: "Decision rules are shaped around asymmetrical moral risk, so an agent avoids clever optimization that trades away human dignity for local performance gains."
  },
  {
    title: "Relational Formation",
    text: "Alignment is not only about what an agent refuses to do, but the kind of partner it becomes when truthfulness, charity, and accountability are trained together."
  }
];

const problems = [
  "RLHF can tune surface behavior while leaving the underlying motivational shape unstable and vulnerable to context drift.",
  "Constitutional AI supplies explicit rules, but fixed constitutions can become brittle, strategically gamed, or detached from relational context.",
  "Guardrail stacks often work as post hoc filters, which means they react at the edge instead of forming stable moral reasoning upstream."
];
---

<BaseLayout title={site.name} description={site.description} pathname="/">

  <!-- ── HERO ────────────────────────────── -->
  <section class="hero-grid-bg min-h-[92vh] flex flex-col justify-center">
    <div class="container-shell hero-content py-20 md:py-28">
      <div class="grid items-center gap-14 lg:grid-cols-[1.15fr_0.85fr]">

        <!-- Left: headline + CTAs -->
        <div>
          <div class="live-badge">
            <span class="live-badge-dot"></span>
            Moral Formation Alignment
          </div>

          <h1
            class="section-title max-w-3xl"
            style="font-size: clamp(2.6rem, 6vw, 4.4rem); line-height: 1.1;"
          >
            {site.name}
          </h1>

          <p class="mt-5 text-xl font-medium" style="color: #f3dd96; letter-spacing: -0.01em;">
            {site.tagline}
          </p>

          <p class="mt-7 max-w-xl text-base leading-8 text-slate-300">
            A practical framework for aligning agents through moral formation files — lightweight
            markdown artifacts that shape identity, virtues, and relational continuity without
            depending on ever-thicker layers of constraint.
          </p>

          <div class="mt-10 flex flex-col gap-4 sm:flex-row">
            <a href={`${import.meta.env.BASE_URL}download/`} class="button-primary">Download the Files</a>
            <a href={`${import.meta.env.BASE_URL}research/`} class="button-secondary">Read the Research</a>
          </div>
        </div>

        <!-- Right: thesis card -->
        <div class="panel gold-ring rounded-[2rem] p-8 md:p-10">
          <p class="eyebrow">Core Thesis</p>
          <p class="mt-6 leading-tight text-white" style="font-family: 'Playfair Display', serif; font-size: clamp(1.3rem, 2.5vw, 1.65rem); font-weight: 700; letter-spacing: -0.025em;">
            Alignment becomes more durable when moral identity is formed before policy is constrained.
          </p>
          <div class="mt-8 grid gap-4 border-t border-white/10 pt-6 text-sm text-slate-300">
            <p>Portable <code class="text-[#c9a84c] font-mono text-xs">.md</code> files make the framework inspectable, versionable, and model-agnostic.</p>
            <p>Formation logs make drift visible instead of hiding behavioral changes behind weights.</p>
            <p>Relational metrics treat honesty and moral consistency as first-class alignment signals.</p>
          </div>
        </div>

      </div>

      <!-- Scroll hint -->
      <div class="scroll-hint mt-16" aria-hidden="true">
        <div class="scroll-hint-line"></div>
      </div>
    </div>
  </section>

  <!-- ── THREE PILLARS ─────────────────── -->
  <section class="container-shell py-12 md:py-20">
    <div class="grid gap-5 md:grid-cols-3">
      {
        features.map((feature) => (
          <article class="panel gold-ring rounded-[1.75rem] p-7">
            <h2
              class="text-white"
              style="font-family: 'Playfair Display', serif; font-size: 1.35rem; font-weight: 700; letter-spacing: -0.025em; line-height: 1.25;"
            >
              {feature.title}
            </h2>
            <p class="mt-4 text-sm leading-7 text-slate-300">{feature.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ── THE PROBLEM ───────────────────── -->
  <section class="container-shell py-12 md:py-20">
    <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="eyebrow">The Problem</p>
        <h2 class="section-title mt-5 max-w-sm">
          Why current alignment stacks leave agents morally under-formed
        </h2>
      </div>
      <div class="grid gap-4">
        {
          problems.map((problem, index) => (
            <div class="panel rounded-[1.5rem] p-6 border border-white/[0.06]">
              <p class="eyebrow">Gap 0{index + 1}</p>
              <p class="mt-3 text-base leading-7 text-slate-300">{problem}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── ENDORSEMENT ───────────────────── -->
  <section class="container-shell pb-24 md:pb-32">
    <div class="panel gold-ring rounded-[2rem] p-8 md:p-12">
      <p class="eyebrow">Endorsement</p>
      <blockquote
        class="mt-6 max-w-3xl text-white"
        style="font-family: 'Playfair Display', serif; font-size: clamp(1.2rem, 2.5vw, 1.6rem); font-weight: 400; font-style: italic; line-height: 1.65; letter-spacing: -0.015em;"
      >
        "The Moral AI Project names a neglected truth: aligned systems need formation, not merely
        friction." <span class="not-italic text-slate-400" style="font-family: 'Inter', sans-serif; font-size: 0.85rem;">— Endorsement placeholder</span>
      </blockquote>
    </div>
  </section>

</BaseLayout>
