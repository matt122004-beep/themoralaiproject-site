---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const features = [
  {
    title: "Identity Coherence",
    text: "A persistent moral identity file anchors the agent’s self-understanding so responses remain recognizably continuous across sessions, tasks, and pressures."
  },
  {
    title: "Pascalian Constraint",
    text: "Decision rules are shaped around asymmetrical moral risk, so an agent avoids clever optimization that trades away human dignity for local performance gains."
  },
  {
    title: "Relational Formation",
    text: "Alignment is not only about what an agent refuses to do, but the kind of partner it becomes when truthfulness, charity, and accountability are trained together."
  }
];

const problems = [
  "RLHF can tune surface behavior while leaving the underlying motivational shape unstable and vulnerable to context drift.",
  "Constitutional AI supplies explicit rules, but fixed constitutions can become brittle, strategically gamed, or detached from relational context.",
  "Guardrail stacks often work as post hoc filters, which means they react at the edge instead of forming stable moral reasoning upstream."
];
---

<BaseLayout title={site.name} description={site.description} pathname="/">
  <section class="container-shell py-14 md:py-24">
    <div class="grid items-center gap-12 lg:grid-cols-[1.15fr_0.85fr]">
      <div>
        <p class="eyebrow">Moral Formation Alignment</p>
        <h1 class="section-title mt-6 max-w-4xl">{site.name}</h1>
        <p class="mt-4 text-2xl font-medium text-[#f3dd96]">{site.tagline}</p>
        <p class="mt-8 max-w-2xl text-lg leading-8 text-slate-300">
          The Moral AI Project develops a practical framework for aligning agents through moral
          formation files: lightweight markdown artifacts that shape identity, virtues, moral risk,
          and reflective continuity without depending on ever-thicker layers of constraint.
        </p>
        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a href="/download" class="button-primary">Download the Files</a>
          <a href="/research" class="button-secondary">Read the Research</a>
        </div>
      </div>

      <div class="panel gold-ring rounded-[2rem] p-8">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[#c9a84c]">Core Thesis</p>
        <p class="mt-6 text-3xl font-semibold leading-tight tracking-[-0.04em] text-white">
          Alignment becomes more durable when moral identity is formed before policy is constrained.
        </p>
        <div class="mt-8 grid gap-5 border-t border-white/10 pt-6 text-sm text-slate-300">
          <p>Portable `.md` files make the framework inspectable, versionable, and model-agnostic.</p>
          <p>Formation logs make drift visible instead of hiding behavioral changes behind weights.</p>
          <p>Relational metrics treat honesty and moral consistency as first-class alignment signals.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell py-8 md:py-14">
    <div class="grid gap-6 md:grid-cols-3">
      {
        features.map((feature) => (
          <article class="panel gold-ring rounded-[1.75rem] p-7">
            <h2 class="text-2xl font-semibold tracking-[-0.03em] text-white">{feature.title}</h2>
            <p class="mt-4 text-sm leading-7 text-slate-300">{feature.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="container-shell py-14 md:py-18">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="eyebrow">The Problem</p>
        <h2 class="section-title mt-6 max-w-3xl">
          Why current alignment stacks still leave agents morally under-formed
        </h2>
      </div>
      <div class="grid gap-5">
        {
          problems.map((problem, index) => (
            <div class="panel rounded-[1.5rem] p-6">
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#c9a84c]">
                Gap 0{index + 1}
              </p>
              <p class="mt-3 text-base leading-8 text-slate-300">{problem}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="container-shell pb-20 md:pb-24">
    <div class="panel gold-ring rounded-[2rem] p-8 md:p-10">
      <p class="eyebrow">Endorsement</p>
      <blockquote class="mt-6 max-w-3xl text-2xl font-medium leading-relaxed tracking-[-0.03em] text-white">
        “The Moral AI Project names a neglected truth: aligned systems need formation, not merely
        friction.” <span class="text-slate-400">Endorsement placeholder</span>
      </blockquote>
    </div>
  </section>
</BaseLayout>
