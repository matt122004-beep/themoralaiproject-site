---
import { navigation, site } from "../data/site";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-[#0a0a0a]/90 backdrop-blur-xl">
  <div class="container-shell flex items-center justify-between py-4">
    <a href={`${import.meta.env.BASE_URL}`} class="flex items-center gap-3">
      <span class="flex h-11 w-11 items-center justify-center rounded-full border border-[rgba(201,168,76,0.35)] bg-[rgba(201,168,76,0.08)] text-sm font-extrabold tracking-[0.2em] text-[#c9a84c]">
        MAI
      </span>
      <span>
        <span class="block text-sm font-semibold text-white">{site.name}</span>
        <span class="block text-xs text-slate-400">{site.tagline}</span>
      </span>
    </a>

    <button
      type="button"
      class="inline-flex rounded-full border border-white/10 p-3 text-white md:hidden"
      aria-expanded="false"
      aria-controls="mobile-nav"
      data-menu-toggle
    >
      <span class="sr-only">Open navigation</span>
      <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current" stroke-width="1.8">
        <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"></path>
      </svg>
    </button>

    <nav class="hidden items-center gap-2 md:flex">
      {
        navigation.map((item) => {
          const active = currentPath === item.href || currentPath.startsWith(`${item.href}/`);
          return (
            <a
              href={item.href}
              class:list={[
                "rounded-full px-4 py-2 text-sm font-medium transition",
                active
                  ? "bg-[rgba(201,168,76,0.14)] text-white"
                  : "text-slate-300 hover:bg-white/5 hover:text-white"
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>
  </div>

  <nav id="mobile-nav" class="container-shell hidden pb-4 md:hidden" data-mobile-nav>
    <div class="panel gold-ring rounded-3xl p-3">
      <div class="grid gap-1">
        {
          navigation.map((item) => {
            const active = currentPath === item.href || currentPath.startsWith(`${item.href}/`);
            return (
              <a
                href={item.href}
                class:list={[
                  "rounded-2xl px-4 py-3 text-sm font-medium transition",
                  active
                    ? "bg-[rgba(201,168,76,0.14)] text-white"
                    : "text-slate-300 hover:bg-white/5 hover:text-white"
                ]}
              >
                {item.label}
              </a>
            );
          })
        }
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.querySelector("[data-menu-toggle]");
  const nav = document.querySelector("[data-mobile-nav]");

  if (toggle instanceof HTMLButtonElement && nav instanceof HTMLElement) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      nav.classList.toggle("hidden");
    });
  }
</script>
