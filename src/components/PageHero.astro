---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="container-shell pt-20 pb-12 md:pt-24 md:pb-16">
  <p class="eyebrow">{eyebrow}</p>
  <h1 class="section-title mt-6 max-w-4xl">{title}</h1>
  <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">{description}</p>
</section>
